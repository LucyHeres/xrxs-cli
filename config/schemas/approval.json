                { "name": "snowIds", "type": "string", "required": true, "description": "批量审批 ID JSON" }
              ],
              "pipeline": {
                "steps": [
                  {
                    "id": "test",
                    "path": "/approve/service/ajax-test-batch-urge",
                    "method": "GET",
                    "encoding": "form",
                    "params": [],
                    "outputKey": "testResult"
                  },
                  {
                    "id": "urge",
                    "path": "/approve/service/ajax-batch-flow-urge",
                    "method": "GET",
                    "encoding": "form",
                    "params": [
                      { "name": "snowIds", "type": "string", "required": true, "description": "批量审批 ID JSON" }
