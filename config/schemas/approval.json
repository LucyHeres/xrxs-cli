              ]
            },
            {
              "name": "safe-urge",
              "description": "安全催办（先检查再催办）",
              "params": [
                { "name": "sid", "type": "string", "required": true, "description": "审批记录 ID" }
              ],
              "pipeline": {
                "steps": [
                  {
                    "id": "test",
                    "path": "/approve/service/ajax-test-urge",
                    "method": "GET",
                    "encoding": "form",
                    "params": [
                      { "name": "sid", "type": "string", "required": true, "description": "审批记录 ID" }
                    ],
                    "outputKey": "testResult"
                  },
                  {
                    "id": "urge",
                    "path": "/approve/service/ajax-flow-urge",
                    "method": "GET",
                    "encoding": "form",
                    "params": [
                      { "name": "sid", "type": "string", "required": true, "description": "审批记录 ID" }
                    ],
                    "outputKey": "result"
                  }
                ]
              }
            },
