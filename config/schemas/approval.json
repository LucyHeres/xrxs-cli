{
  "version": "1",
  "products": [
    {
      "name": "approval",
      "description": "审批模块：列表查询、详情查看、审批操作、类型管理、角色和委托",
      "tools": [
        {
          "name": "list",
          "description": "审批列表查询与操作",
          "subtools": [
            {
              "name": "search",
              "description": "搜索审批列表",
              "path": "/approve/service/ajax-get-approve-list",
              "method": "POST",
              "encoding": "form-nested",
              "output": {"unwrap": "data.result.data"},
              "params": [
                {"name": "keyword", "type": "string", "default": "", "description": "搜索关键词", "inBody": true},
                {"name": "status", "type": "string", "default": "", "description": "审批状态: 0=审批中, 1=已通过, 2=已驳回, 3=已撤销", "inBody": true},
                {"name": "flow-group-id", "type": "string", "default": "", "description": "审批分组 ID", "inBody": true},
                {"name": "page", "type": "int", "default": 1, "description": "页码"},
                {"name": "page-size", "type": "int", "default": 20, "description": "每页条数"}
              ],
              "body": {
                "order": {"0": {"field": "", "dir": ""}},
                "start": "{{.page}}",
                "length": "{{.pageSize}}",
                "search": {"value": "filter:keyword={{.keyword}}&flowType=&status={{.status}}&employeeId=&departmentId=&approveIds=&addtime=&modtime=&formContent=&flowGroupId={{.flowGroupId}}", "regex": false},
                "speedy": {"value": "filter:searchType=&flowType=&employeeId="},
                "monthFilter": 4,
                "speedySearch": false
              }
            },
            {
              "name": "admin-search",
              "description": "获取管理/关联审批列表",
              "path": "/approve/service/ajax-get-admin-approve-list",
              "method": "POST",
              "encoding": "form-nested",
              "output": {"unwrap": "data.result.data"},
              "params": [
                {"name": "keyword", "type": "string", "default": "", "description": "搜索关键词", "inBody": true},
                {"name": "status", "type": "string", "default": "", "description": "审批状态", "inBody": true},
                {"name": "flow-group-id", "type": "string", "default": "", "description": "审批分组 ID", "inBody": true},
                {"name": "page", "type": "int", "default": 1, "description": "页码"},
                {"name": "page-size", "type": "int", "default": 20, "description": "每页条数"}
              ],
              "body": {
                "order": {"0": {"field": "", "dir": ""}},
                "start": "{{.page}}",
                "length": "{{.pageSize}}",
                "search": {"value": "filter:keyword={{.keyword}}&flowType=&status={{.status}}&employeeId=&departmentId=&approveIds=&addtime=&modtime=&formContent=&flowGroupId={{.flowGroupId}}", "regex": false},
                "speedy": {"value": "filter:searchType=&flowType=&employeeId="},
                "monthFilter": 4,
                "speedySearch": false
              }
            },
            {
              "name": "admin-search-all",
              "description": "审批全局搜索（所有审批）",
              "path": "/approve/service/ajax-get-admin-approve-list-all",
              "method": "POST",
              "encoding": "form-nested",
              "output": {"unwrap": "data.result.data"},
              "params": [
                {"name": "keyword", "type": "string", "default": "", "description": "搜索关键词", "inBody": true},
                {"name": "page", "type": "int", "default": 1, "description": "页码"},
                {"name": "page-size", "type": "int", "default": 20, "description": "每页条数"}
              ],
              "body": {
                "order": {"0": {"field": "", "dir": ""}},
                "start": "{{.page}}",
                "length": "{{.pageSize}}",
                "search": {"value": "filter:keyword={{.keyword}}", "regex": false},
                "speedy": {"value": "filter:searchType=&flowType=&employeeId="},
                "monthFilter": 4,
                "speedySearch": false
              }
            },
            {
              "name": "speedy-search-type",
              "description": "获取猜你想搜下拉选项",
              "path": "/approve/service/ajax-get-approve-speedy-search-type",
              "method": "POST",
              "encoding": "form",
              "params": []
            },
            {
              "name": "filter-num",
              "description": "获取各状态审批数量统计",
              "path": "/approve/service/ajax-get-filter-num",
              "method": "GET",
              "encoding": "form",
              "params": []
            },
            {
              "name": "open-status",
              "description": "获取审批开启状态",
              "path": "/approve/service/ajax-get-approve-open-status",
              "method": "GET",
              "encoding": "form",
              "params": []
            },
            {
              "name": "approve",
              "description": "通过审批",
              "path": "/approve/service/ajax-pass-approve-step",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true},
                {"name": "flow-step-id", "type": "string", "default": "", "description": "审批步骤 ID"},
                {"name": "comment", "type": "string", "default": "", "description": "审批意见"}
              ]
            },
            {
              "name": "reject",
              "description": "驳回审批",
              "path": "/approve/service/ajax-rejected-approve-step",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true},
                {"name": "flow-step-id", "type": "string", "default": "", "description": "审批步骤 ID"},
                {"name": "comment", "type": "string", "default": "", "description": "驳回意见"}
              ]
            },
            {
              "name": "batch-approve",
              "description": "批量通过/驳回审批",
              "path": "/approve/service/ajax-batch-operation-approve-step",
              "method": "POST",
              "encoding": "form-nested",
              "params": [
                {"name": "type", "type": "int", "description": "操作类型: 1=通过, 2=驳回", "required": true},
                {"name": "data", "type": "string", "description": "批量数据 JSON 数组", "required": true}
              ],
              "body": {"type": "{{.type}}", "data": "{{.data}}"}
            },
            {
              "name": "batch-forward",
              "description": "批量转交审批",
              "path": "/approve/service/ajax-batch-change-approve-step",
              "method": "POST",
              "encoding": "form-nested",
              "params": [
                {"name": "type", "type": "int", "description": "操作类型", "required": true},
                {"name": "data", "type": "string", "description": "批量数据 JSON 数组", "required": true}
              ],
              "body": {"type": "{{.type}}", "data": "{{.data}}"}
            },
            {
              "name": "cancel",
              "description": "撤销审批",
              "path": "/approve/service/ajax-close-approve-step",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true},
                {"name": "flow-step-id", "type": "string", "default": "", "description": "审批步骤 ID"},
                {"name": "remark", "type": "string", "default": "", "description": "撤销说明"}
              ]
            },
            {
              "name": "forward",
              "description": "转交审批",
              "path": "/approve/service/ajax-change-approve-step",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true},
                {"name": "flow-step-id", "type": "string", "default": "", "description": "审批步骤 ID", "queryName": "flowStepId"},
                {"name": "approver-id", "type": "string", "default": "", "description": "当前审批人 ID", "queryName": "approverId"},
                {"name": "next-approver-id", "type": "string", "description": "转交目标审批人 ID", "required": true, "queryName": "nextApproverId"},
                {"name": "remark", "type": "string", "default": "", "description": "转交说明"}
              ]
            },
            {
              "name": "urge",
              "description": "催办审批（普通审批）",
              "path": "/approve/service/ajax-flow-urge",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true}
              ]
            },
            {
              "name": "batch-urge",
              "description": "批量催办审批",
              "path": "/approve/service/ajax-batch-flow-urge",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "data", "type": "string", "description": "批量审批 ID JSON", "required": true}
              ]
            },
            {
              "name": "test-urge",
              "description": "检查是否可以催办（单个）",
              "path": "/approve/service/ajax-test-urge",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true}
              ]
            },
            {
              "name": "test-batch-urge",
              "description": "检查是否可以批量催办",
              "path": "/approve/service/ajax-test-batch-urge",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "data", "type": "string", "description": "批量审批 ID JSON", "required": true}
              ]
            },
            {
              "name": "export",
              "description": "导出审批列表",
              "path": "/approve/service/ajax-export-flow",
              "method": "POST",
              "encoding": "form-nested",
              "params": [
                {"name": "keyword", "type": "string", "default": "", "description": "搜索关键词", "inBody": true},
                {"name": "flow-group-id", "type": "string", "default": "", "description": "审批分组 ID", "inBody": true},
                {"name": "name", "type": "string", "default": "", "description": "导出文件名", "inBody": true}
              ],
              "body": {
                "order": {"0": {"field": "", "dir": ""}},
                "start": 0,
                "length": 9999,
                "search": {"value": "filter:keyword={{.keyword}}&flowType=&status=&employeeId=&departmentId=&approveIds=&addtime=&modtime=&formContent=&flowGroupId={{.flowGroupId}}", "regex": false},
                "speedy": {"value": "filter:searchType=&flowType=&employeeId="},
                "monthFilter": 0,
                "speedySearch": false,
                "name": "{{.name}}"
              }
            },
            {
              "name": "export-check",
              "description": "导出前检查是否有导出权限",
              "path": "/approve/service/ajax-export-flow-check",
              "method": "POST",
              "encoding": "form-nested",
              "params": [
                {"name": "keyword", "type": "string", "default": "", "description": "搜索关键词", "inBody": true},
                {"name": "status", "type": "string", "default": "", "description": "审批状态", "inBody": true},
                {"name": "flow-group-id", "type": "string", "default": "", "description": "审批分组 ID", "inBody": true}
              ],
              "body": {
                "order": {"0": {"field": "", "dir": ""}},
                "start": 0,
                "length": 9999,
                "search": {"value": "filter:keyword={{.keyword}}&flowType=&status={{.status}}&employeeId=&departmentId=&approveIds=&addtime=&modtime=&formContent=&flowGroupId={{.flowGroupId}}", "regex": false},
                "speedy": {"value": "filter:searchType=&flowType=&employeeId="},
                "monthFilter": 0,
                "speedySearch": false
              }
            },
            {
              "name": "get-last-sign",
              "description": "管理员获取上次签名信息",
              "path": "/approve/service/ajax-get-last-sign",
              "method": "POST",
              "encoding": "form",
              "params": []
            },
            {
              "name": "search-employee",
              "description": "搜索部门或员工（用于评论@功能）",
              "path": "/approve/service/ajax-search-department-or-employee",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "keyword", "type": "string", "default": "", "description": "搜索关键词"}
              ]
            },
            {
              "name": "change-prove-status",
              "description": "领取证明 / 更改证明状态",
              "path": "/approve/service/ajax-change-prove-status",
              "method": "GET",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true},
                {"name": "prove-status", "type": "int", "default": 0, "description": "证明状态", "queryName": "proveStatus"}
              ]
            },
            {
              "name": "cancel-handover",
              "description": "撤销离职交接审批",
              "path": "/approve/service/ajax-cancel-handover-approval",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true},
                {"name": "cancel-reason", "type": "string", "default": "", "description": "撤销原因", "queryName": "cancelReason"}
              ]
            },
            {
              "name": "get-confirm-date",
              "description": "获取离职确认日期",
              "path": "/approve/service/ajax-get-confirm-date",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true}
              ]
            },
            {
              "name": "transfer-approval",
              "description": "转交离职交接审批",
              "path": "/approve/service/ajax-transfer-approval",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true},
                {"name": "director-employee-id", "type": "string", "description": "转交目标员工 ID", "required": true, "queryName": "directorEmployeeId"},
                {"name": "transfer-reason", "type": "string", "default": "", "description": "转交原因", "queryName": "transferReason"}
              ]
            }
          ]
        },
        {
          "name": "detail",
          "description": "审批详情查看",
          "subtools": [
            {
              "name": "get",
              "description": "获取审批详情",
              "path": "/approve/service/ajax-get-approve-detail",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true},
                {"name": "type", "type": "int", "default": 1, "description": "详情类型: 1=详情, 2=打印"}
              ]
            },
            {
              "name": "path",
              "description": "获取审批流程路径/历史",
              "path": "/approve/service/ajax-get-approve-path",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true}
              ]
            },
            {
              "name": "print",
              "description": "获取审批打印数据",
              "path": "/approve/service/ajax-flow-print",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true}
              ]
            },
            {
              "name": "edit-history",
              "description": "获取审批编辑历史",
              "path": "/approve/service/ajax-get-page-edit-history",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true}
              ]
            },
            {
              "name": "save-page-edit",
              "description": "保存审批页面编辑",
              "path": "/approve/service/ajax-save-page-edit",
              "method": "POST",
              "encoding": "form-nested",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true, "inBody": true},
                {"name": "data", "type": "string", "description": "编辑数据 JSON", "required": true, "inBody": true}
              ],
              "body": {"sid": "{{.sid}}", "data": "{{.data}}"}
            },
            {
              "name": "overtime-hour",
              "description": "获取加班时间信息",
              "path": "/approve/service/ajax-get-approve-over-timehour",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true}
              ]
            },
            {
              "name": "back-process-step",
              "description": "获取可退回的审批节点列表",
              "path": "/approve/service/ajax-get-back-process-step",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true}
              ]
            },
            {
              "name": "save-back-process-step",
              "description": "执行审批退回操作",
              "path": "/approve/service/ajax-back-process-step",
              "method": "POST",
              "encoding": "form-nested",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true, "inBody": true},
                {"name": "data", "type": "string", "description": "退回节点数据 JSON", "required": true, "inBody": true}
              ],
              "body": {"sid": "{{.sid}}", "data": "{{.data}}"}
            },
            {
              "name": "increase-process-step",
              "description": "执行加签操作",
              "path": "/approve/service/ajax-increase-process-step",
              "method": "POST",
              "encoding": "form-nested",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true, "inBody": true},
                {"name": "data", "type": "string", "description": "加签数据 JSON", "required": true, "inBody": true}
              ],
              "body": {"sid": "{{.sid}}", "data": "{{.data}}"}
            },
            {
              "name": "open-mask-field",
              "description": "掩码字段获取明文",
              "path": "/approve/service/ajax-open-mask-fields",
              "method": "POST",
              "encoding": "form-nested",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true, "inBody": true},
                {"name": "data", "type": "string", "description": "掩码字段数据 JSON", "required": true, "inBody": true}
              ],
              "body": {"sid": "{{.sid}}", "data": "{{.data}}"}
            },
            {
              "name": "check-form-required",
              "description": "审批通过前校验必填项",
              "path": "/approve/service/ajax-check-form-required",
              "method": "POST",
              "encoding": "form-nested",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true, "inBody": true},
                {"name": "data", "type": "string", "description": "校验数据 JSON", "required": true, "inBody": true}
              ],
              "body": {"sid": "{{.sid}}", "data": "{{.data}}"}
            },
            {
              "name": "check-biz-field",
              "description": "审批业务字段校验",
              "path": "/approve/service/ajax-check-biz-field",
              "method": "POST",
              "encoding": "form-nested",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true, "inBody": true},
                {"name": "data", "type": "string", "description": "校验数据 JSON", "required": true, "inBody": true}
              ],
              "body": {"sid": "{{.sid}}", "data": "{{.data}}"}
            },
            {
              "name": "handover-detail",
              "description": "获取离职交接审批详情",
              "path": "/approve/service/ajax-get-handover-approve-detail",
              "method": "POST",
              "encoding": "form",
              "params": [
                {"name": "sid", "type": "string", "description": "审批记录 ID", "required": true},
                {"name": "is-print", "type": "int", "default": 0, "description": "是否打印视图", "queryName": "isPrint"}
              ]
            }
          ]
        },
        {
          "name": "manage",
          "description": "审批类型管理",
          "subtools": [
            {
              "name": "list-groups",
              "description": "列出所有审批分组",
              "path": "/approve/service/ajax-get-flow-group",
              "method": "GET",
              "encoding": "form",
              "params": []
            },
            {
              "name": "save-group",
              "description": "新增或重命名审批分组",
              "path": "/approve/service/ajax-save-flow-group",
              "method": "POST",
              "encoding": "form-nested",
              "params": [
                {"name": "name", "type": "string", "description": "分组名称", "required": true, "inBody": true},
                {"name": "group-id", "type": "string", "default": "", "description": "分组 ID（重命名时传入）", "inBody": true, "queryName": "groupId"}
              ],
              "body": {"name": "{{.name}}", "groupId": "{{.groupId}}"}
            },
            {
              "name": "remove-group",
              "description": "删除审批分组",
              "path": "/approve/service/ajax-remove-flow-group",
              "method": "POST",
              "encoding": "form-nested",
              "params": [
                {"name": "group-id", "type": "string", "description": "分组 ID", "required": true, "inBody": true, "queryName": "groupId"}
              ],
              "body": {"groupId": "{{.groupId}}"}
            },
            {
              "name": "list",
              "description": "按分组列出审批类型",
              "path": "/approve/service/ajax-get-flow-setting",
              "method": "GET",
              "encoding": "form",
              "params": [
                {"name": "group-id", "type": "string", "default": "", "description": "审批分组 ID", "queryName": "groupId"}
              ]
            },
            {
              "name": "get",
              "description": "获取审批类型详情",
              "path": "/approve/service/ajax-get-flow-setting-new",
              "method": "GET",
              "encoding": "form",
              "params": [
                {"name": "setting-id", "type": "string", "description": "审批类型 ID", "required": true, "queryName": "flowSettingId"}
              ]
            },
            {
              "name": "check-name",
              "description": "检查审批类型名称是否重复",
              "path": "/approve/service/ajax-check-flow-name",
              "method": "GET",
              "encoding": "form",
              "params": [
                {"name": "name", "type": "string", "description": "审批类型名称", "required": true, "queryName": "flowName"},
                {"name": "name-eng", "type": "string", "default": "", "description": "英文名称", "queryName": "flowNameEng"},
                {"name": "setting-id", "type": "string", "default": "", "description": "排除的类型 ID", "queryName": "flowSettingId"}
              ]
            },
            {
